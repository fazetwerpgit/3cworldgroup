rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Is the signed-in caller a back-office or field-management user?
    function isManagement() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.role in ['admin', 'operations'] ||
             u.fieldRole in ['l1_manager', 'l2_manager'];
    }

    // Authenticated users can read their own user profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin can read all users
    match /users/{userId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'operations'];
    }

    // Sales - authenticated users can read and create
    match /sales/{saleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Notifications - users can read/update their own
    match /notifications/{notifId} {
      allow read, update: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Training resources - authenticated can read
    match /training/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // User progress - users manage their own
    match /userProgress/{docId} {
      allow read, write: if request.auth != null;
    }

    // Leaderboard - authenticated can read
    match /leaderboard/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Onboarding item progress - a user reads their own; management reads all.
    // All writes go through the server (Admin SDK), which bypasses these rules,
    // so client writes are denied.
    match /userOnboarding/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isManagement());
      allow write: if false;
    }

    // Channel credentialing progress - same access model as userOnboarding.
    match /userChannelOnboarding/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isManagement());
      allow write: if false;
    }

    // Onboarding invites carry token hashes; only the server (Admin SDK) and the
    // public token route may touch them. No direct client access.
    match /onboardingInvites/{docId} {
      allow read, write: if false;
    }

    // Candidate onboarding submissions - server-only (Admin SDK).
    match /candidateOnboarding/{docId} {
      allow read, write: if false;
    }

    // Encrypted sensitive onboarding fields (SSN, DL#). Server-only (Admin SDK).
    // No client ever reads or writes these; the admin reveal goes through an
    // admin-gated, token-verified API route, not direct Firestore access.
    match /userSensitive/{uid} {
      allow read, write: if false;
    }

    // Audit log of sensitive-field reveals. Server-only.
    match /sensitiveAccessLog/{logId} {
      allow read, write: if false;
    }

    // Rep-form submissions (Fiber Report, Expedite Order). Server-only (Admin
    // SDK); reps submit and management reads via gated API routes, not direct
    // client Firestore access.
    match /fiberReports/{id} {
      allow read, write: if false;
    }
    match /expediteOrders/{id} {
      allow read, write: if false;
    }
    match /payrollDisputes/{id} {
      allow read, write: if false;
    }
    match /leadsRequests/{id} {
      allow read, write: if false;
    }
    match /formOptions/{key} {
      allow read, write: if false;
    }
    match /managerInterviews/{id} {
      allow read, write: if false;
    }
    // Bug reports — any user submits via a gated API route; admins review. Server-only.
    match /bugReports/{id} {
      allow read, write: if false;
    }
    // Per-form submission-alert toggles. Server-only; admins flip via a gated route.
    match /formAlerts/{key} {
      allow read, write: if false;
    }
  }
}
